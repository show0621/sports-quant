# 資料來源：hybrid（預設，nba_api+ESPN+運彩）| api_sports
# DATA_SOURCE=hybrid

# API-Sports 金鑰（選填，混合模式下僅作備援）https://api-sports.io/
API_SPORTS_KEY=

# 選填：自動將 data/sportsbet.db 推送到 GitHub（Streamlit / CLI）
GITHUB_TOKEN=
GITHUB_DB_SYNC_ENABLED=true
# 聯盟 ID（預設 NBA=12、MLB=1，一般不需改）
# API_SPORTS_LEAGUE_NBA=12
# API_SPORTS_LEAGUE_MLB=1
# 免費方案通常僅 2022–2024；付費後可調高上限
# API_SPORTS_SEASON_MIN=2022
# API_SPORTS_SEASON_MAX=2024

# 畢達哥拉斯指數
PYTH_EXPONENT_NBA=14.0
PYTH_EXPONENT_MLB=1.83
USE_DYNAMIC_MLB_EXPONENT=false

# 貝氏修正
BAYES_HOME_ADVANTAGE=0.03
BAYES_RECENT_GAMES=5
BAYES_RECENT_WEIGHT=0.25
BAYES_INJURY_PENALTY=0.05

# 台灣運彩
TAIWAN_VIG_RETURN_RATE=0.76
INITIAL_BANKROLL=100000
KELLY_FRACTION=0.25
MAX_BET_FRACTION=0.05
MIN_EV_THRESHOLD=0.02

# 威剛爬蟲（舊 HTML；現以運彩 Blob 為主）
WANDA_BASE_URL=https://www.twsport.com.tw
WANDA_REQUEST_DELAY_SEC=1.5

# 台灣運彩 Blob API（公開 JSON，無需金鑰）
SPORTSLOTTERY_BLOB_BASE=https://blob.sportslottery.com.tw/apidata

# JBot 歷史賠率 https://sportsbot.tech/api/sportslottery/
JBOT_TOKEN=
JBOT_SPORT_CODE_NBA=BKB
JBOT_SPORT_CODE_MLB=BSB

# 告警
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
LINE_NOTIFY_TOKEN=
