# 複製為 secrets.toml（本機）或在 Streamlit Cloud → Settings → Secrets 貼上

API_SPORTS_KEY = "你的_api-sports_金鑰"

# 選填：自動將 data/sportsbet.db 推送到 GitHub（需 repo 寫入權限）
# GITHUB_TOKEN = "ghp_xxxxxxxx"

# 免費 API 賽季上限（預設 2024）；付費後可改為當季，例如 2025
# API_SPORTS_SEASON_MAX = 2024

# 選填
# JBOT_TOKEN = ""
# PYTH_EXPONENT_NBA = 14.0
# PYTH_EXPONENT_MLB = 1.83
